# Variables de entorno para Tyr.

GIT_ROOT="git@github.com:Avantio"
GIT_BASE="git@github.com:Avantio-Webs"

INTEGRATIONS_DIR="ruta_hacia_datosBroker"
WEBS_DIR="ruta_hacia_clients"
FRAMEWORK_DIR="ruta_hacia_framework"

MSSQL_USER="web-dev"
MSSQL_PASSWORD="GjsN&cc7zo@sRvLC5Y"
MSSQL_SERVER="172.16.0.131"
MSSQL_DATABASE="crs_int"

# Variables de entorno para PRE
VPN_SERVER="vpn.avantio.dev:4433"
VPN_USER="usuario"
VPN_PASSWORD="contraseña"

VPN_DOMAIN="avantio"
VPN_NAME="Avantio"


AI_VENDOR=anthropic
# REQUIRED for whichever vendor AI_VENDOR points to (or is passed explicitly per-call).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# Overrides the vendor's default model for plain complete()/stream() calls (not the priority
# routing below, which has its own per-tier overrides).
AI_MODEL=
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=4096
AI_MAX_RETRIES=3

# --- AIVendorManager: Dynamic Model Routing (resolvePriority / completeWithPriority) -------------
# Per-vendor, per-tier model overrides. Leave blank to use the built-in defaults (see MODEL_TIERS
# in AIVendorManager.ts). Only the tier(s) for your configured AI_VENDOR actually matter.
ANTHROPIC_AI_MODEL_CHEAP=
ANTHROPIC_AI_MODEL_BALANCED=
ANTHROPIC_AI_MODEL_FLAGSHIP=
OPENAI_AI_MODEL_CHEAP=
OPENAI_AI_MODEL_BALANCED=
OPENAI_AI_MODEL_FLAGSHIP=
GEMINI_AI_MODEL_CHEAP=
GEMINI_AI_MODEL_BALANCED=
GEMINI_AI_MODEL_FLAGSHIP=

ANTHROPIC_THINKING_BUDGET_NONE=0
ANTHROPIC_THINKING_BUDGET_LOW=1024
ANTHROPIC_THINKING_BUDGET_MEDIUM=4096
ANTHROPIC_THINKING_BUDGET_HIGH=8192
ANTHROPIC_THINKING_BUDGET_MAX=16384
GEMINI_THINKING_BUDGET_NONE=0
GEMINI_THINKING_BUDGET_LOW=1024
GEMINI_THINKING_BUDGET_MEDIUM=4096
GEMINI_THINKING_BUDGET_HIGH=8192
GEMINI_THINKING_BUDGET_MAX=16384
# OpenAI's reasoning models ('o' series, gpt-5*) only accept a fixed vocabulary for
# reasoning_effort — no token budget, and no 'none' (those models can't disable reasoning).
OPENAI_REASONING_EFFORT_LOW=low
OPENAI_REASONING_EFFORT_MEDIUM=medium
OPENAI_REASONING_EFFORT_HIGH=high
OPENAI_REASONING_EFFORT_MAX=high

# --- AIVendorManager: priority routing (resolvePriority / completeWithPriority) ------------------
# Per-priority overrides for model tier (cheap|balanced|flagship) and thinking effort
# (none|low|medium|high|max). Values below are the built-in defaults (see PRIORITY_ROUTING in
# AIVendorManager.ts): tier only escalates past 'cheap' at media-prioridad, and only reaches
# 'flagship' at the top level — bias the ladder toward cheap and raise thinking effort first
# before reaching for a pricier tier. An invalid value falls back to the default.
AI_PRIORITY_BAJA_TIER=cheap
AI_PRIORITY_BAJA_THINKING=none
AI_PRIORITY_BAJA_MEDIA_TIER=cheap
AI_PRIORITY_BAJA_MEDIA_THINKING=high
AI_PRIORITY_MEDIA_TIER=balanced
AI_PRIORITY_MEDIA_THINKING=none
AI_PRIORITY_MEDIA_ALTA_TIER=balanced
AI_PRIORITY_MEDIA_ALTA_THINKING=high
AI_PRIORITY_ALTA_TIER=balanced
AI_PRIORITY_ALTA_THINKING=max
AI_PRIORITY_MUY_ALTA_TIER=flagship
AI_PRIORITY_MUY_ALTA_THINKING=max

# --- TokenManager -----------------------------------------------------------------------------
# Upper bound (estimated tokens) allowed for a single prompt before assertWithinLimit() rejects it.
DEFAULT_MAX_INPUT_TOKENS=100000

# --- AIContextManager: guideline snapshot (generateContextFile) --------------------------------
SNAPSHOT_TREE_MAX_DEPTH=5
SNAPSHOT_TREE_MAX_ENTRIES_PER_DIR=250
SNAPSHOT_SECTION_MAX_CHARS=40000

# --- AIContextManager: context file search (findContextFiles) ----------------------------------
# How many directory levels up (toward the repo root) and down (into subfolders) to look for
# README.md / CLAUDE.md / AGENTS.md / CONTEXT.md / .cursorrules / copilot-instructions.md.
CONTEXT_SEARCH_UPWARD_LEVELS=4
CONTEXT_SEARCH_DOWNWARD_LEVELS=3
# Cap on how many context files are used once found (closest to the target directory wins).
MAX_CONTEXT_FILES=6


