# Alias para incrementar versiones, admite comentarios
# gtz = V1.0.(Z+1)
# gty = V1.(Y+1).0
# gtx = V(X+1).0.0
# Ejemplo: gtx "Nueva versión lanzada"
alias gtz='increment_patch() {
latest_tag=$(git describe --tags --abbrev=0 2>/dev/null)

if [[ -z "$latest_tag" ]]; then
echo "No hay tags en el repositorio. Creando el primer tag V1.0.0..."
new_tag="V1.0.0"
else
prefix=$(echo "$latest_tag" | grep -oE "^[^0-9]*")
version_number=${latest_tag#"$prefix"}

if [[ ! "$version_number" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
echo "Error: No se pudo extraer correctamente la versión del último tag ($latest_tag)."
return 1
fi

IFS="." read -r major minor patch <<<"$version_number"
patch=$((patch + 1))
new_tag="${prefix}${major}.${minor}.${patch}"
fi

comment="$*"
[[ -z "$comment" ]] && comment="Nuevo release $new_tag"

git tag -a "$new_tag" -m "$comment"
git push origin "$new_tag"

echo "Nuevo tag creado y enviado: $new_tag"
}; increment_patch'

alias gty='increment_minor() {
latest_tag=$(git describe --tags --abbrev=0 2>/dev/null)

if [[ -z "$latest_tag" ]]; then
echo "No hay tags en el repositorio. Creando el primer tag V1.0.0..."
new_tag="V1.0.0"
else
prefix=$(echo "$latest_tag" | grep -oE "^[^0-9]*")
version_number=${latest_tag#"$prefix"}

if [[ ! "$version_number" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
echo "Error: No se pudo extraer correctamente la versión del último tag ($latest_tag)."
return 1
fi

IFS="." read -r major minor patch <<<"$version_number"
minor=$((minor + 1))
patch=0
new_tag="${prefix}${major}.${minor}.${patch}"
fi

comment="$*"
[[ -z "$comment" ]] && comment="Nuevo release $new_tag"

git tag -a "$new_tag" -m "$comment"
git push origin "$new_tag"

echo "Nuevo tag creado y enviado: $new_tag"
}; increment_minor'

alias gtx='increment_major() {
latest_tag=$(git describe --tags --abbrev=0 2>/dev/null)

if [[ -z "$latest_tag" ]]; then
echo "No hay tags en el repositorio. Creando el primer tag V1.0.0..."
new_tag="V1.0.0"
else
prefix=$(echo "$latest_tag" | grep -oE "^[^0-9]*")
version_number=${latest_tag#"$prefix"}

if [[ ! "$version_number" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
echo "Error: No se pudo extraer correctamente la versión del último tag ($latest_tag)."
return 1
fi

IFS="." read -r major minor patch <<<"$version_number"
major=$((major + 1))
minor=0
patch=0
new_tag="${prefix}${major}.${minor}.${patch}"
fi

comment="$*"
[[ -z "$comment" ]] && comment="Nuevo release $new_tag"

git tag -a "$new_tag" -m "$comment"
git push origin "$new_tag"

echo "Nuevo tag creado y enviado: $new_tag"
}; increment_major'

